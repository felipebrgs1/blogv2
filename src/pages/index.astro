---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { calculateReadingTime } from "../utils/reading-time";

const posts = (await getCollection("post", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const featured = posts[0];
const recent = posts.slice(1);
const featuredReadingTime = featured ? calculateReadingTime(featured.body) : "";

const longDateFormat = {
	day: "2-digit",
	month: "long",
	year: "numeric",
	timeZone: "UTC",
} as const;

const shortDateFormat = {
	day: "2-digit",
	month: "short",
	year: "numeric",
	timeZone: "UTC",
} as const;
---

<BaseLayout
	title="The Lab"
	description="Ensaios e artigos técnicos em Astro + Markdown"
>
	<main class="mx-auto w-full max-w-5xl px-6 py-12">
		{
			featured && (
				<section class="mb-16 grid grid-cols-1 items-center gap-10 lg:grid-cols-12">
					<div class="lg:col-span-7">
						<a href={`/post/${featured.slug}`} class="group block">
							<div class="aspect-16/10 overflow-hidden rounded-xl border border-slate-200 bg-slate-100 dark:border-slate-800 dark:bg-slate-900">
								{featured.data.coverImage ? (
									<Image
										src={featured.data.coverImage}
										alt={featured.data.title}
										format="webp"
										quality={70}
										widths={[640, 960, 1280]}
										sizes="(max-width: 1024px) 100vw, 58vw"
										class="h-full w-full object-cover opacity-80 transition group-hover:scale-105 group-hover:opacity-100"
										loading="eager"
										fetchpriority="high"
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center bg-linear-to-br from-[rgb(48,110,232)]/25 to-slate-600/20 dark:from-[rgb(73,100,110)]/30">
										<span class="font-serif text-2xl text-slate-700 dark:text-slate-200">
											Featured
										</span>
									</div>
								)}
							</div>
						</a>
					</div>

					<div class="lg:col-span-5">
						<p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-[rgb(48,110,232)] dark:text-[rgb(73,100,110)]">
							Destaque
						</p>
						<h1 class="mb-5 font-serif text-4xl font-bold leading-tight">
							<a
								href={`/post/${featured.slug}`}
								class="transition-colors hover:text-[rgb(48,110,232)] dark:hover:text-[rgb(73,100,110)]"
							>
								{featured.data.title}
							</a>
						</h1>
						<p class="mb-5 text-lg text-slate-600 dark:text-slate-300">
							{featured.data.description}
						</p>
						<p class="text-sm text-slate-500 dark:text-slate-400">
							{featured.data.date.toLocaleDateString("pt-BR", longDateFormat)} •{" "}
							{featuredReadingTime}
						</p>
					</div>
				</section>
			)
		}

		<section class="mb-8 flex items-end justify-between">
			<h2 class="font-serif text-3xl font-bold">Recentes</h2>
			<a
				class="text-sm font-semibold text-[rgb(48,110,232)] hover:underline dark:text-[rgb(73,100,110)]"
				href="/post">Ver todos</a
			>
		</section>

		<section class="grid grid-cols-1 gap-x-12 gap-y-12 md:grid-cols-2">
			{
				recent.map((post, index) => (
					<article class="group">
						<a href={`/post/${post.slug}`} class="mb-4 block">
							<div class="aspect-video overflow-hidden rounded-xl border border-slate-200 bg-slate-100 dark:border-slate-800 dark:bg-slate-900">
								{post.data.coverImage ? (
									<Image
										src={post.data.coverImage}
										alt={post.data.title}
										format="webp"
										quality={68}
										widths={[360, 540, 720]}
										sizes="(max-width: 768px) 100vw, 50vw"
										class="h-full w-full object-cover opacity-85 transition group-hover:scale-105 group-hover:opacity-100"
										loading={index < 2 ? "eager" : "lazy"}
										fetchpriority={index < 2 ? "high" : "auto"}
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center bg-linear-to-br from-[rgb(48,110,232)]/20 to-slate-500/20 dark:from-[rgb(73,100,110)]/30">
										<span class="font-serif text-xl text-slate-700 dark:text-slate-200">
											Post
										</span>
									</div>
								)}
							</div>
						</a>
						<p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">
							{post.data.category}
						</p>
						<h3 class="mb-3 font-serif text-2xl font-bold leading-snug">
							<a
								href={`/post/${post.slug}`}
								class="transition-colors group-hover:text-[rgb(48,110,232)] dark:group-hover:text-[rgb(73,100,110)]"
							>
								{post.data.title}
							</a>
						</h3>
						<p class="mb-3 text-slate-600 dark:text-slate-300">
							{post.data.description}
						</p>
						<p class="text-sm text-slate-500 dark:text-slate-400">
							{post.data.date.toLocaleDateString("pt-BR", shortDateFormat)}
						</p>
					</article>
				))
			}
		</section>
	</main>
</BaseLayout>
