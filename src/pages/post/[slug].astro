---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
	const posts = await getCollection('post', ({ data }) => !data.draft);

	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.date.toLocaleDateString('pt-BR', {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
	timeZone: 'UTC',
});
const readingTime = calculateReadingTime(post.body);
---

<BaseLayout
	title={`${post.data.title} | The Lab`}
	description={post.data.description}
>
	<main class='mx-auto w-full max-w-3xl px-6 py-14'>
		<div
			class='post-hero-wrap mb-10 rounded-xl border border-slate-200 dark:border-slate-800'
			id='post-hero-wrap'
		>
			{
				post.data.coverImage ? (
					<Image
						src={post.data.coverImage}
						alt={post.data.title}
						format='webp'
						quality={72}
						widths={[640, 960, 1280]}
						sizes='(max-width: 768px) 100vw, 768px'
						class='post-hero-image'
						id='post-hero-image'
						loading='eager'
						fetchpriority='high'
					/>
				) : (
					<div class='flex aspect-video h-full w-full items-center justify-center bg-linear-to-br from-[rgb(48,110,232)]/20 to-slate-500/20 dark:from-[rgb(73,100,110)]/30'>
						<span class='font-serif text-2xl text-slate-700 dark:text-slate-200'>
							Post
						</span>
					</div>
				)
			}
		</div>

		<header class='mb-12'>
			<div
				class='mb-5 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-[rgb(48,110,232)] dark:text-[rgb(73,100,110)]'
			>
				<span>{post.data.category}</span>
				<span class='h-1 w-1 rounded-full bg-slate-400 dark:bg-slate-600'
				></span>
				<span>{post.data.tags.join(' · ') || 'post'}</span>
			</div>

			<h1 class='mb-6 font-serif text-4xl font-bold leading-tight md:text-5xl'>
				{post.data.title}
			</h1>
			<p class='mb-6 text-xl text-slate-700 dark:text-slate-300'>
				{post.data.description}
			</p>

			<div
				class='flex flex-wrap items-center gap-3 text-sm text-slate-500 dark:text-slate-400'
			>
				<span class='font-medium text-slate-700 dark:text-slate-300'
					>{post.data.author}</span
				>
				<span>•</span>
				<time datetime={post.data.date.toISOString()}>{formattedDate}</time>
				<span>•</span>
				<span>{readingTime}</span>
			</div>
		</header>

		<article class='post-content max-w-none text-lg leading-relaxed'>
			<Content />
		</article>
	</main>

	<script is:inline>
		(() => {
			const heroWrap = document.getElementById('post-hero-wrap');
			const heroImage = document.getElementById('post-hero-image');
			if (!heroWrap || !heroImage) return;

			let ticking = false;
			const update = () => {
				const rect = heroWrap.getBoundingClientRect();
				const viewport = window.innerHeight || 1;
				const centerOffset = rect.top + rect.height / 2 - viewport / 2;
				const normalized = Math.max(Math.min(centerOffset / viewport, 1), -1);

				const translateY = normalized * -70;
				const opacity = Math.max(1 - Math.abs(normalized) * 0.55, 0.35);

				heroWrap.style.setProperty('--hero-shift', `${translateY}px`);
				heroWrap.style.setProperty('--hero-opacity', String(opacity));
				ticking = false;
			};

			const onScroll = () => {
				if (ticking) return;
				ticking = true;
				window.requestAnimationFrame(update);
			};

			update();
			window.addEventListener('scroll', onScroll, { passive: true });
			window.addEventListener('resize', onScroll);
		})();

		(() => {
			const images = Array.from(
				document.querySelectorAll('.post-content img[alt*="Comparativo de"]'),
			);

			const openFullscreen = (src, alt) => {
				const modal = document.createElement('div');
				modal.className = 'fullscreen-img-modal';

				const modalImg = document.createElement('img');
				modalImg.src = src;
				modalImg.alt = alt;

				modal.appendChild(modalImg);
				document.body.appendChild(modal);

				requestAnimationFrame(() => {
					modal.classList.add('active');
				});

				modal.addEventListener('click', () => {
					modal.classList.remove('active');
					setTimeout(() => {
						modal.remove();
					}, 300);
				});
			};

			if (images.length > 1) {
				const firstP = images[0].closest('p');
				if (!firstP) return;

				const wrapper = document.createElement('div');
				wrapper.className = 'carousel-wrapper';
				firstP.parentNode.insertBefore(wrapper, firstP);

				const carousel = document.createElement('div');
				carousel.className = 'post-carousel';
				wrapper.appendChild(carousel);

				const btnPrev = document.createElement('button');
				btnPrev.className = 'carousel-btn prev';
				btnPrev.innerHTML = '&#10094;';
				btnPrev.setAttribute('aria-label', 'Imagem anterior');

				const btnNext = document.createElement('button');
				btnNext.className = 'carousel-btn next';
				btnNext.innerHTML = '&#10095;';
				btnNext.setAttribute('aria-label', 'Próxima imagem');

				wrapper.appendChild(btnPrev);
				wrapper.appendChild(btnNext);

				images.forEach((img) => {
					const p = img.closest('p');

					const slide = document.createElement('div');
					slide.className = 'carousel-slide';
					slide.appendChild(img);

					carousel.appendChild(slide);

					if (p && p.textContent.trim() === '' && p.parentNode) {
						p.parentNode.removeChild(p);
					}

					slide.addEventListener('click', () =>
						openFullscreen(img.src, img.alt),
					);
				});

				const updateButtons = () => {
					const scrollLeft = carousel.scrollLeft;
					const maxScroll = carousel.scrollWidth - carousel.clientWidth;

					if (scrollLeft > 10) {
						btnPrev.style.opacity = '1';
						btnPrev.style.pointerEvents = 'auto';
					} else {
						btnPrev.style.opacity = '0';
						btnPrev.style.pointerEvents = 'none';
					}

					if (scrollLeft < maxScroll - 10) {
						btnNext.style.opacity = '1';
						btnNext.style.pointerEvents = 'auto';
					} else {
						btnNext.style.opacity = '0';
						btnNext.style.pointerEvents = 'none';
					}
				};

				carousel.addEventListener('scroll', updateButtons, { passive: true });
				window.addEventListener('resize', updateButtons);

				// Timeout to ensure elements have layed out correctly before checking scrollWidth
				setTimeout(updateButtons, 100);

				btnPrev.addEventListener('click', () => {
					carousel.scrollBy({
						left: -carousel.clientWidth * 0.85,
						behavior: 'smooth',
					});
				});

				btnNext.addEventListener('click', () => {
					carousel.scrollBy({
						left: carousel.clientWidth * 0.85,
						behavior: 'smooth',
					});
				});
			} else if (images.length === 1) {
				// Standalone image wrapper for styling fallback
				const p = images[0].closest('p');
				if (p) p.classList.add('post-carousel-single');

				images[0].addEventListener('click', () =>
					openFullscreen(images[0].src, images[0].alt),
				);
			}
		})();
	</script>
</BaseLayout>
