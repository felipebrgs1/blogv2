---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateReadingTime } from '../../utils/reading-time';
import { getPostSlug } from '../../utils/post';

const posts = (await getCollection('post', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const longDateFormat = {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
	timeZone: 'UTC',
} as const;
---

<BaseLayout
	title='Posts | The Lab'
	description='Arquivo de posts em Markdown'
>
	<main class='mx-auto w-full max-w-3xl px-6 py-14'>
		<header class='mb-12'>
			<p
				class='mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[rgb(48,110,232)] dark:text-[rgb(73,100,110)]'
			>
				Arquivo
			</p>
			<h1 class='font-serif text-5xl font-bold'>Posts</h1>
		</header>

		<div class='space-y-8'>
			{
				posts.map((post, index) => (
					<article class='rounded-xl border border-slate-200 p-6 transition hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700'>
						<a
							href={`/post/${getPostSlug(post.id)}`}
							class='mb-5 block'
						>
							<div class='aspect-video overflow-hidden rounded-xl border border-slate-200 bg-slate-100 dark:border-slate-800 dark:bg-slate-900'>
								{post.data.coverImage ? (
									<Image
										src={post.data.coverImage}
										alt={post.data.title}
										format='webp'
										quality={68}
										widths={[360, 540, 720]}
										sizes='(max-width: 768px) 100vw, 768px'
										class='h-full w-full object-cover opacity-85 transition hover:scale-105 hover:opacity-100'
										loading={index < 2 ? 'eager' : 'lazy'}
										fetchpriority={index < 2 ? 'high' : 'auto'}
									/>
								) : (
									<div class='flex h-full w-full items-center justify-center bg-linear-to-br from-[rgb(48,110,232)]/20 to-slate-500/20 dark:from-[rgb(73,100,110)]/30'>
										<span class='font-serif text-xl text-slate-700 dark:text-slate-200'>
											Post
										</span>
									</div>
								)}
							</div>
						</a>
						<p class='mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400'>
							{post.data.category}
						</p>
						<h2 class='mb-3 font-serif text-3xl font-bold leading-tight'>
							<a
								href={`/post/${getPostSlug(post.id)}`}
								class='transition-colors hover:text-[rgb(48,110,232)] dark:hover:text-[rgb(73,100,110)]'
							>
								{post.data.title}
							</a>
						</h2>
						<p class='mb-4 text-slate-600 dark:text-slate-300'>
							{post.data.description}
						</p>
						<p class='text-sm text-slate-500 dark:text-slate-400'>
							{post.data.date.toLocaleDateString('pt-BR', longDateFormat)} •{' '}
							{calculateReadingTime(post.body)}
						</p>
					</article>
				))
			}
		</div>
	</main>
</BaseLayout>
